{
  "name": "@helle253/pi-peon",
  "version": "0.1.0",
  "description": "Pi extension that forwards pi lifecycle events to peon-ping / OpenPeon.",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "keywords": [
    "pi-package",
    "pi",
    "pi-peon",
    "openpeon",
    "peon-ping",
    "cesp"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "bundlecheck": "esbuild extensions/pi-peon.ts --bundle --platform=node --format=esm --external:@mariozechner/pi-coding-agent --outfile=/tmp/pi-peon-check.js",
    "format": "prettier --write .",
    "check": "yarn typecheck && yarn bundlecheck"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-peon.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.3",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3"
  }
}
